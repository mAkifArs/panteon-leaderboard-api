{
  "name": "panteon-leaderboard-api",
  "version": "0.1.0",
  "description": "Weekly leaderboard API for an idle-game economy. Fastify + Postgres + Redis + MongoDB.",
  "type": "module",
  "private": true,
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "bun --hot run src/server.ts",
    "start": "bun run src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run scripts/migrate.ts",
    "db:rollback": "bun run scripts/rollback.ts",
    "db:distribute": "bun run scripts/distribute.ts",
    "seed": "bun run scripts/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/sensible": "^6.0.1",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.4.1",
    "mongodb": "^6.10.0",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.14.0",
    "ioredis-mock": "^8.13.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vitest": "^2.1.4"
  }
}
