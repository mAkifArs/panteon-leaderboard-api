# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# PostgreSQL — source of truth (users, earnings, pools, payouts)
DATABASE_URL=postgres://leaderboard:leaderboard@localhost:5433/leaderboard

# Redis — live leaderboard, distributed lock, weekly pool counter
REDIS_URL=redis://localhost:6379

# MongoDB — weekly snapshots, prize distribution audit
MONGO_URL=mongodb://localhost:27017
MONGO_DB=leaderboard

# CORS — comma-separated list of allowed origins. Use '*' for dev
# wide-open. Default in src/config/env.ts already covers Vite/CRA/
# Next dev ports, so this var is only required when a non-default
# origin needs to be allowed.
# Production (Cloudflare Pages frontend):
#   CORS_ORIGINS=https://panteon-leaderboard-web.pages.dev
